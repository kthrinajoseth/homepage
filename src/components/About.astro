---
const base = import.meta.env.BASE_URL;

const benefits = [
  "Experience teaching students from diverse cultures and age groups",
  "Personalized lessons tailored to your pace and learning style",
  "Strong focus on pronunciation and correct usage",
  "Ongoing support to help you progress with confidence",
  "Convenient live classes via Zoom - learn from anywhere",
];

const expectations = [
  "Start reading in Spanish from the very beginning",
  "Apply pronunciation rules from the first lesson",
  "Gradually begin to think in Spanish",
  "Hold a basic conversation within two weeks",
  "Learn grammar progressively so it sticks naturally",
  "Get plenty of practice - visual, auditory, written, and spoken",
];
---

<section id="about" class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="text-accent text-sm tracking-widest uppercase font-medium">About Me</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold mt-2 text-navy">
        Hello! I'm Kathrina
      </h2>
      <p class="text-muted mt-4 text-lg">Your future Spanish teacher</p>
    </div>

    <!-- About Content -->
    <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
      <!-- Kathrina's Photo -->
      <div class="relative flex justify-center">
        <div class="relative">
          <img 
            src={`${base}images/kathrina-photo.jpg`}
            alt="Kathrina - Spanish Teacher" 
            class="w-48 h-48 md:w-64 md:h-64 rounded-full object-cover shadow-xl border-4 border-white"
          />
          <!-- Decorative element -->
          <div class="absolute -bottom-2 -right-2 w-20 h-20 bg-accent/20 rounded-full -z-10"></div>
          <div class="absolute -top-2 -left-2 w-16 h-16 bg-light-gray/30 rounded-full -z-10"></div>
        </div>
      </div>

      <!-- Text Content -->
      <div>
        <p class="text-secondary text-lg leading-relaxed mb-6">
          Welcome to my teaching space! I'm from <strong>Colombia</strong>, a native Spanish speaker with over 
          <strong>5 years of experience</strong> helping students of all ages - from 3-year-old children to adults - 
          learn and enjoy the Spanish language.
        </p>
        <p class="text-secondary text-lg leading-relaxed mb-6">
          My classes are taught live via <strong>Zoom</strong>, allowing you to learn comfortably from anywhere in the world.
        </p>
        <p class="text-secondary text-lg leading-relaxed">
          In my lessons, you will learn Spanish in a structured yet natural way, with a strong focus on 
          <strong>practical fluency from day one</strong>.
        </p>
      </div>
    </div>

    <!-- My Approach -->
    <div class="bg-cream rounded-3xl p-8 md:p-12 mb-16">
      <h3 class="font-display text-3xl font-bold mb-6 text-center text-navy">My Approach</h3>
      <p class="text-secondary text-lg leading-relaxed text-center max-w-3xl mx-auto">
        I combine the spontaneity of <strong>natural conversation</strong> with the academic structure needed to 
        truly master the language. I work with teaching materials tailored to your level and goals, ensuring a 
        learning experience that is <strong>effective, engaging, and professional</strong>.
      </p>
    </div>

    <!-- Video Section -->
    <div class="mb-16">
      <div class="max-w-3xl mx-auto">
        <div class="relative w-full aspect-video rounded-2xl overflow-hidden shadow-xl">
          <iframe 
            src="https://www.youtube.com/embed/tHuhiuz7WHI" 
            title="Kathrin Spanish Lessons Introduction"
            class="absolute inset-0 w-full h-full"
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>

    <!-- Two Columns: Benefits & Expectations -->
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Why Learn With Me -->
      <div>
        <h3 class="font-display text-2xl font-bold mb-6 text-navy">
          Why learn Spanish with me?
        </h3>
        <ul class="space-y-4">
          {benefits.map((benefit) => (
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-secondary">{benefit}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- What to Expect -->
      <div>
        <h3 class="font-display text-2xl font-bold mb-6 text-navy">
          What can you expect?
        </h3>
        <ul class="space-y-4">
          {expectations.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-accent flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-secondary">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Guarantee Banner -->
    <div class="mt-16 text-center">
      <div class="inline-block bg-accent text-white px-8 py-4 rounded-full">
        <span class="font-display text-xl font-semibold">
          Guaranteed fluency, regardless of your current level
        </span>
      </div>
    </div>
  </div>
</section>
