---
---

<section id="home" class="min-h-screen flex items-center justify-center pt-20 pb-16 px-4 bg-cream relative overflow-hidden">
  <!-- Background Decorative Elements -->
  <div class="absolute top-10 left-10 opacity-10">
    <img src="/images/hola-decoration.jpg" alt="" class="w-32 md:w-48 blur-sm" aria-hidden="true" />
  </div>
  <div class="absolute bottom-10 right-10 opacity-10">
    <img src="/images/hola-decoration.jpg" alt="" class="w-32 md:w-48 blur-sm" aria-hidden="true" />
  </div>

  <div class="max-w-6xl mx-auto text-center relative z-10">
    <!-- Decorative Element -->
    <div class="mb-6">
      <span class="inline-block text-accent text-lg tracking-widest uppercase font-medium">Welcome to</span>
    </div>
    
    <!-- Main Logo -->
    <div class="mb-8">
      <img 
        src="/images/kathrin-logo.png"
        alt="KATHRIN - Spanish Lessons" 
        class="mx-auto w-full max-w-2xl h-auto"
      />
    </div>

    <!-- Tagline -->
    <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      Learn Spanish with a native Colombian teacher. 
      Personalized live lessons via Zoom from anywhere in the world.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a 
        href="#services" 
        class="bg-accent text-white px-8 py-4 rounded-full text-lg font-semibold hover:bg-accent/90 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1"
      >
        Book a Lesson
      </a>
      <a 
        href="#about" 
        class="border-2 border-primary text-primary px-8 py-4 rounded-full text-lg font-semibold hover:bg-primary hover:text-white transition-all duration-300"
      >
        Learn More
      </a>
    </div>

    <!-- Trust Badges -->
    <div class="mt-16 flex flex-wrap justify-center gap-8 text-muted">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span>5+ Years Experience</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span>Native Speaker</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span>All Ages Welcome</span>
      </div>
    </div>
  </div>
</section>
